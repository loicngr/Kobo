{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/server/**/*", "src/mcp-server/**/*"],
  "exclude": ["node_modules", "dist", "src/client", "src/__tests__"]
}
